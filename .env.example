# Tempo Agent-to-Agent Payment Demo
# Generate accounts with: npx mppx account create

# Service Agent (recipient) — private key for receiving payments
RECIPIENT_KEY=0x_YOUR_RECIPIENT_PRIVATE_KEY_HERE

# Client Agent (payer) — private key for making payments
CLIENT_KEY=0x_YOUR_CLIENT_PRIVATE_KEY_HERE

# Server port (optional, defaults to 3000)
# PORT=3000

# Server URL for client to connect to (optional, defaults to http://localhost:3000)
# SERVER_URL=http://localhost:3000
